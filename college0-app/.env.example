# File MUST live in college0-app/.env (next to package.json).
# After editing, restart: Ctrl+C then npm run dev

VITE_SUPABASE_URL=https://dxiwpudmhygeuqhcjgem.supabase.co
# Dashboard → Project Settings → API
# Prefer the legacy anon JWT (starts with eyJ) unless all Edge Functions you use are deployed with
# verify_jwt = false in supabase/config.toml: publishable keys (sb_publishable_...) are not JWTs,
# and the Edge gateway rejects them as Bearer when verify_jwt is true.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Edge Functions — not prefixed with VITE_ so Vite does not ship them to the browser.
# For hosted Supabase, set the same names under Dashboard → Edge Functions → Secrets.
GEMINI_API_KEY=
# Optional: chat model (default gemini-2.0-flash)
# GEMINI_MODEL=
# Optional: RAG embeddings (defaults gemini-embedding-001, 768 dims — must match DB migration)
# GEMINI_EMBEDDING_MODEL=
# GEMINI_EMBEDDING_DIM=

